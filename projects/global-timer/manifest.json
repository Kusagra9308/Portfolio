{
  "manifest_version": 3,
  "name": "Global Timer & Stopwatch",
  "version": "1.0.0",
  "description": "A floating header-bar timer and stopwatch for every tab.",
  "permissions": ["storage", "notifications", "alarms"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Timer Control",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["inject-styles.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-visibility": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "MacCtrl+Shift+L"
      },
      "description": "Toggle the timer visibility"
    }
  }
}
